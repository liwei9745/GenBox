# Docker Compose release defaults. Rename this file to .env before starting.
APP_MODE=prod
GENBOX_PORT=8891
GENBOX_CONTAINER_NAME=genbox
GENBOX_IMAGE=ghcr.io/liwei9745/genbox:2.5.0
ALLOWED_ORIGINS=http://localhost:8891,http://127.0.0.1:8891

# Optional: configure model providers in the GenBox UI after first startup.
# Do not place real secrets in source control.

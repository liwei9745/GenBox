# GenBox Environment Configuration
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# ──────────────────────────────────────────────────────────────
# App Mode
# ──────────────────────────────────────────────────────────────
# "prod" = admin key required for API access (DEFAULT, recommended for VPS)
# "dev" = no auth required (local development only)
# APP_MODE=prod

# Admin key (auto-generated on first run in prod mode)
# ADMIN_KEY=your-admin-key-here

# ──────────────────────────────────────────────────────────────
# Security Settings
# ──────────────────────────────────────────────────────────────
# CORS allowed origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:8891,http://127.0.0.1:8891

# SSL verification for outbound requests (true/false)
# WARNING: Only set to true if you have valid SSL certificates
# VERIFY_SSL=false

# Rate limiting (requests per minute)
# RATE_LIMIT_GENERATE=10
# RATE_LIMIT_API=60

# ──────────────────────────────────────────────────────────────
# Image Generation Providers
# ──────────────────────────────────────────────────────────────

# OpenAI / GPT Image 2
GPT_IMAGE_API_KEY=
GPT_IMAGE_BASE_URL=https://api.openai.com/v1

# Google Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Qwen (通义千问)
QWEN_API_KEY=
QWEN_BASE_URL=http://localhost:8090/v1

# Agnes AI
AGNES_API_KEY=
AGNES_BASE_URL=

# ──────────────────────────────────────────────────────────────
# LLM Provider (for prompt optimization, optional)
# ──────────────────────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

# ╔════════════════════════════════════════════════════════════╗
# ║                   GenBox 环境配置                         ║
# ╠════════════════════════════════════════════════════════════╣
# ║  复制此文件为 .env 并填写你的配置                          ║
# ║  cp .env.example .env                                    ║
# ╚════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────
# 运行模式（必填）
# ──────────────────────────────────────────────────────────────
# dev  = 开发模式（无需认证，仅限本机访问）
# prod = 正式模式（需要管理员密钥，适合 VPS/公网部署）
APP_MODE=dev

# ──────────────────────────────────────────────────────────────
# 管理员密钥（prod 模式必填）
# ──────────────────────────────────────────────────────────────
# 首次启动时自动生成，也可手动设置
# 建议使用随机字符串：openssl rand -base64 16
# ADMIN_KEY=your-secret-admin-key-here

# ──────────────────────────────────────────────────────────────
# CORS 允许的源（prod 模式必填）
# ──────────────────────────────────────────────────────────────
# 如果通过浏览器远程访问，必须设置为你的域名或 IP
# 多个源用逗号分隔
# ALLOWED_ORIGINS=http://your-vps-ip:8891,http://your-domain.com:8891
ALLOWED_ORIGINS=http://localhost:8891,http://127.0.0.1:8891

# ──────────────────────────────────────────────────────────────
# 生图模型配置（至少配置一个）
# ──────────────────────────────────────────────────────────────

# OpenAI GPT Image
# GPT_IMAGE_API_KEY=sk-xxx
# GPT_IMAGE_BASE_URL=https://api.openai.com/v1
# GPT_IMAGE_MODEL=gpt-image-2
# GPT_IMAGE_SIZE=1024x1024
# GPT_IMAGE_QUALITY=high

# Gemini
# GEMINI_API_KEY=sk-xxx
# GEMINI_BASE_URL=
# GEMINI_MODEL=gemini-3.1-flash-preview-05-20

# Qwen (通义千问)
# QWEN_API_KEY=sk-xxx
# QWEN_BASE_URL=https://apihub.agnes-ai.com/v1
# QWEN_MODEL=qwen2.5-72b-instruct

# ──────────────────────────────────────────────────────────────
# 视频模型配置（可选）
# ──────────────────────────────────────────────────────────────

# Agnes Video
# AGNES_API_KEY=sk-xxx
# AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# ──────────────────────────────────────────────────────────────
# LLM 提示词优化（可选）
# ──────────────────────────────────────────────────────────────

# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=
# LLM_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────────
# SSL 验证（一般不需要修改）
# ──────────────────────────────────────────────────────────────
# VERIFY_SSL=false

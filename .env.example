# Image Gen Studio - 环境变量配置
# 复制此文件为 .env，填入你的配置

# ════════════════════════════════════════════════════════
# 安全策略
# ════════════════════════════════════════════════════════
# prod=启用登录认证, dev=免认证(开发模式)
APP_MODE=dev
# ADMIN_KEY 首次启动自动生成，勿手动修改
ADMIN_KEY=

# ════════════════════════════════════════════════════════
# 🎨 生图模型
# ════════════════════════════════════════════════════════
GPT_IMAGE_API_KEY=
GPT_IMAGE_BASE_URL=https://api.openai.com/v1

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

QWEN_API_KEY=
QWEN_BASE_URL=

# ════════════════════════════════════════════════════════
# 🎬 生视频模型
# ════════════════════════════════════════════════════════
AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# ════════════════════════════════════════════════════════
# 🤖 LLM 提示词优化（可选）
# ════════════════════════════════════════════════════════
LLM_API_KEY=
LLM_BASE_URL=

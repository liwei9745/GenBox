# GenBox local development template.
# Copy to .env only when running from source. Release clients work without it.

APP_MODE=dev
GENBOX_PORT=8892
TAILSCALE_SERVE_PORT=8893
ALLOWED_ORIGINS=http://localhost:8892,http://127.0.0.1:8892

# Disable automatic browser opening in CI or headless environments.
# GENBOX_NO_BROWSER=1

# Production administrator key. Leave unset during local development.
# ADMIN_KEY=replace-with-a-long-random-value

# Authenticated image Push sources as a JSON object.
# GENBOX_PUSH_KEYS={"chatgpt2api-dev":"replace-with-a-long-random-key"}
# GENBOX_PUSH_MAX_BYTES=26214400

# Optional provider defaults. Providers can also be configured in the UI.
# GPT_IMAGE_API_KEY=replace-me
# GPT_IMAGE_BASE_URL=https://api.openai.com/v1
# GPT_IMAGE_MODEL=gpt-image-2
# GPT_IMAGE_SIZE=1024x1024
# GPT_IMAGE_QUALITY=high

# GEMINI_API_KEY=replace-me
# GEMINI_BASE_URL=
# GEMINI_MODEL=gemini-3.1-flash-preview-05-20

# QWEN_API_KEY=replace-me
# QWEN_BASE_URL=
# QWEN_MODEL=

# AGNES_API_KEY=replace-me
# AGNES_BASE_URL=

# Optional prompt-assistance model.
# LLM_API_KEY=replace-me
# LLM_BASE_URL=
# LLM_MODEL=

# TLS verification should normally remain enabled.
# VERIFY_SSL=true
